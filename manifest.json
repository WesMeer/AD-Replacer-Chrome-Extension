{
  "manifest_version": 3,
  "name": "Meme Ad Replacer",
  "version": "1.0",
  "description": "Replaces ads on web pages with memes for a more enjoyable browsing experience.",
"permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "testpage.html",
        "testpage.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}